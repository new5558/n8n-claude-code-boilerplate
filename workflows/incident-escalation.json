      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, -240],
      "id": "b1b2c3d4-0006-4000-8000-000000000006",
      "name": "Lookup Status Page",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "var orig = $('Set P1 Policy').first().json;\nvar httpData = $input.first().json;\nvar error = httpData.error;\nvar statusPageOk = !error;\nvar NL = String.fromCharCode(10);\nvar lines = [];\nlines.push(orig.emoji + ' **P1 INCIDENT: ' + orig.title + '**');\nlines.push('Service: ' + orig.service);\nlines.push('Reporter: ' + orig.reporter);\nlines.push('SLA: ' + orig.sla);\nlines.push('Escalate to: ' + orig.escalateTo);\nlines.push('Status page: ' + (statusPageOk ? 'reachable' : 'UNREACHABLE'));\nif (orig.description) { lines.push('Details: ' + orig.description); }\nlines.push('Time: ' + orig.timestamp);\nreturn [{ json: { formatted: lines.join(NL), severity: orig.severity, title: orig.title, service: orig.service, isBusinessHours: orig.isBusinessHours, sla: orig.sla } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, -240],
      "id": "b1b2c3d4-0007-4000-8000-000000000007",
