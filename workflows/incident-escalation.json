            { "id": "p1-escalate", "name": "escalateTo", "value": "on-call engineer + engineering manager", "type": "string" },
            { "id": "p1-channel", "name": "channel", "value": "critical-alerts", "type": "string" },
            { "id": "p1-emoji", "name": "emoji", "value": "=\\ud83d\\udea8", "type": "string" }
