              "outputLabel": "P3"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "sev-p4", "leftValue": "={{ $json.severity }}", "rightValue": "P4", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputLabel": "P4"
            }
          ]
        },
        "options": {}
      },
