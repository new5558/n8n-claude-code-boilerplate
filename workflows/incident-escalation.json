{
  "name": "Incident Escalation Pipeline",
  "nodes": [
    {
      "parameters": {
        "path": "incident-escalation",
        "httpMethod": "POST",
        "responseMode": "onReceived",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [0, 0],
      "id": "b1b2c3d4-0001-4000-8000-000000000001",
      "name": "Webhook",
      "webhookId": "b1b2c3d4-0001-4000-8000-100000000001"
    },
    {
      "parameters": {
        "jsCode": "var body = $input.first().json.body || {};\nvar title = (body.title || '').trim();\nvar severity = (body.severity || '').toUpperCase().trim();\nvar service = (body.service || 'unknown').trim();\nvar reporter = (body.reporter || 'anonymous').trim();\nvar description = (body.description || '').substring(0, 500);\n\nvar validSeverities = ['P1', 'P2', 'P3', 'P4'];\nvar isValid = title.length > 0 && validSeverities.indexOf(severity) !== -1;\n\nvar hour = $now.hour;\nvar weekday = $now.weekday;\nvar isBusinessHours = weekday >= 1 && weekday <= 5 && hour >= 9 && hour < 18;\n\nreturn [{ json: { title: title, severity: severity, service: service, reporter: reporter, description: description, isValid: isValid, isBusinessHours: isBusinessHours, timestamp: $now.toISO(), hour: hour, weekday: weekday } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0],
      "id": "b1b2c3d4-0002-4000-8000-000000000002",
      "name": "Validate and Enrich"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "valid-check",
              "leftValue": "={{ $json.isValid }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [440, 0],
