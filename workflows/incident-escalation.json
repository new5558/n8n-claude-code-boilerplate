        "jsCode": "var item = $input.first().json;\nvar NL = String.fromCharCode(10);\nvar lines = [];\nlines.push('='.repeat(40));\nlines.push(item.formatted);\nlines.push('='.repeat(40));\nlines.push('Business hours: ' + (item.isBusinessHours ? 'Yes' : 'No (after hours)'));\nreturn [{ json: { card: lines.join(NL), severity: item.severity, title: item.title, service: item.service, isBusinessHours: item.isBusinessHours, sla: item.sla } }];"
      },
