N8N_HOST=https://your-n8n-instance.example.com/
N8N_API_KEY=your-api-key-here

# n8n credential IDs (referenced in workflow JSON files via $ENV_VAR placeholders)
N8N_DISCORD_CREDENTIAL_ID=your-discord-webhook-credential-id
N8N_GMAIL_CREDENTIAL_ID=your-gmail-oauth2-credential-id
N8N_CALENDAR_CREDENTIAL_ID=your-google-calendar-credential-id
